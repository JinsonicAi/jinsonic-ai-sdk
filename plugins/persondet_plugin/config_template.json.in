  "component": {
    "parentType": "algorithm-component",
    "label": {
      "zh": "行人检测",
      "en": "Person Detection"
    },
    "type": "@PLUGIN_NAME@",
    "component": {
      "isDrawingArea": true,
      "formList": [
        {
          "type": "divider",
          "name": {
            "zh": "检测区域（可选，留空按全画面报警）",
            "en": "Detection Region (Optional, full-frame when empty)"
          }
        },
        {
          "type": "regionDraw",
          "key": "area",
          "name": {
            "zh": "检测区域",
            "en": "Detection Area"
          },
          "enabled": true,
          "default": []
        },
        {
          "type": "subdivider",
          "name": {
            "zh": "区域规则",
            "en": "Region Rules"
          },
          "disabledWhenEmpty": "area"
        },
        {
          "type": "switch",
          "name": {
            "zh": "启用进/出检测",
            "en": "Enable Enter/Leave"
          },
          "key": "region_enable_enter",
          "default": true
        },
        {
          "type": "switch",
          "name": {
            "zh": "启用离开检测",
            "en": "Enable Leave"
          },
          "key": "region_enable_leave",
          "default": true
        },
        {
          "type": "switch",
          "name": {
            "zh": "启用徘徊检测",
            "en": "Enable Loiter"
          },
          "key": "region_enable_loiter",
          "default": false
        },
        {
          "type": "input",
          "name": {
            "zh": "徘徊触发时间(s)",
            "en": "Loiter Seconds"
          },
          "key": "region_loiter_sec",
          "default": "10"
        },
        {
          "type": "input",
          "name": {
            "zh": "徘徊冷却(s)",
            "en": "Loiter Cooldown"
          },
          "key": "region_loiter_cooldown",
          "default": "30"
        },
        {
          "type": "switch",
          "name": {
            "zh": "启用离岗检测",
            "en": "Enable Absence"
          },
          "key": "region_enable_absence",
          "default": false
        },
        {
          "type": "input",
          "name": {
            "zh": "离岗触发时间(s)",
            "en": "Absence Seconds"
          },
          "key": "region_absence_sec",
          "default": "30"
        },
        {
          "type": "input",
          "name": {
            "zh": "离岗冷却(s)",
            "en": "Absence Cooldown"
          },
          "key": "region_absence_cooldown",
          "default": "60"
        },
        {
          "type": "switch",
          "name": {
            "zh": "启用拥挤检测",
            "en": "Enable Crowd"
          },
          "key": "region_enable_crowd",
          "default": false
        },
        {
          "type": "input",
          "name": {
            "zh": "拥挤阈值",
            "en": "Crowd Threshold"
          },
          "key": "region_crowd_threshold",
          "default": "10"
        },
        {
          "type": "input",
          "name": {
            "zh": "拥挤恢复间隔",
            "en": "Crowd Recover Gap"
          },
          "key": "region_crowd_recover_gap",
          "default": "2"
